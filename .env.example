# Mood Tracker — environment template. Copy to .env and fill values.
# NEVER commit real secrets. Secrets are provided via env / secret manager.

# Runtime
ENVIRONMENT=local
LOG_LEVEL=INFO
# Deployment environment: local | prod (default local). With APP_ENV=prod an empty
# API_KEY makes the app refuse to start (fail-closed app-level auth guard, ADR-009).
APP_ENV=local

# Database (local = SQLite, prod = PostgreSQL)
DATABASE_URL=sqlite+aiosqlite:///./mood_tracker.db
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/mood_tracker

# App-level static API key (ADR-009): shared secret authenticating the client app.
# Sent as the X-API-Key header on every /api/v1/* request (not /health).
# Required in prod (enables the auth barrier); leave empty to disable locally.
API_KEY=

# OpenAI
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4o
OPENAI_TRANSCRIBE_MODEL=whisper-1
OPENAI_TEMPERATURE=0.7
OPENAI_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=1

# Rate limiting (memory = local, redis = prod)
RATE_LIMIT_BACKEND=memory
REDIS_URL=
RATE_LIMIT_DEFAULT_MAX=120
RATE_LIMIT_DEFAULT_WINDOW=60
RATE_LIMIT_LLM_MAX=10
RATE_LIMIT_LLM_WINDOW=60
RATE_LIMIT_TRANSCRIPTION_MAX=20
RATE_LIMIT_TRANSCRIPTION_WINDOW=60
# Enable only behind a trusted proxy/LB that sets X-Forwarded-For (secondary IP
# key for rate limiting on LLM/STT routes).
TRUST_PROXY_HEADERS=false

# Limits
MAX_AUDIO_BYTES=10485760
MAX_TEXT_CHARS=4000

# Gamification
POINTS_PER_ENTRY=20

# CORS (JSON array or comma-separated list of origins; empty = none)
CORS_ALLOW_ORIGINS=
